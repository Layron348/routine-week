# Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Public HTTPS URL of the Mini App (same as web service URL in production)
MINI_APP_URL=http://localhost:8000

# Optional: only if frontend and API are on different domains
# VITE_API_URL=https://your-api.example.com/api

# Local dev only (frontend vite proxy uses backend on :8000)
BACKEND_URL=http://localhost:8000

# Production database path (Docker/Fly use /data)
# DATA_DIR=data

# PostgreSQL example (optional, instead of SQLite):
# DATABASE_URL=postgresql://user:pass@host:5432/routine
